{
  "realm": "sunbird-serve",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      { "name": "sAdmin", "description": "Platform-wide super admin" },
      { "name": "nAdmin", "description": "Need agency admin" },
      { "name": "nCoordinator", "description": "Need coordinator" },
      { "name": "vAdmin", "description": "Volunteer agency admin" },
      { "name": "vCoordinator", "description": "Volunteer coordinator" },
      { "name": "Volunteer", "description": "Volunteer user" }
    ]
  },
  "groups": [
    {
      "name": "need-agency-demo",
      "attributes": {
        "agencyId": ["agency-need-001"],
        "agencyType": ["NeedAgency"]
      }
    },
    {
      "name": "volunteer-agency-demo",
      "attributes": {
        "agencyId": ["agency-vol-001"],
        "agencyType": ["VolunteerAgency"]
      }
    }
  ],
  "clients": [
    {
      "clientId": "serve-ui",
      "name": "Serve UI (React Frontend)",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:5173/*",
        "http://localhost:9000/api/v1/serve-need/swagger-ui/oauth2-redirect.html"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:5173",
        "http://localhost:9000"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3000/*##http://localhost:5173/*"
      },
      "protocolMappers": [
        {
          "name": "realm-roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String"
          }
        },
        {
          "name": "agencyId-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "agencyId",
            "user.attribute": "agencyId",
            "jsonType.label": "String"
          }
        },
        {
          "name": "agencyType-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "agencyType",
            "user.attribute": "agencyType",
            "jsonType.label": "String"
          }
        },
        {
          "name": "email-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "email",
            "user.attribute": "email",
            "jsonType.label": "String"
          }
        },
        {
          "name": "username-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "preferred_username",
            "user.attribute": "username",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "needadmin@test.org",
      "email": "needadmin@test.org",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Need",
      "lastName": "Admin",
      "attributes": {
        "agencyId": ["agency-need-001"],
        "agencyType": ["NeedAgency"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "test1234",
          "temporary": false
        }
      ],
      "realmRoles": ["nAdmin"],
      "groups": ["need-agency-demo"]
    },
    {
      "username": "ncoord@test.org",
      "email": "ncoord@test.org",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Need",
      "lastName": "Coordinator",
      "attributes": {
        "agencyId": ["agency-need-001"],
        "agencyType": ["NeedAgency"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "test1234",
          "temporary": false
        }
      ],
      "realmRoles": ["nCoordinator"],
      "groups": ["need-agency-demo"]
    },
    {
      "username": "vadmin@test.org",
      "email": "vadmin@test.org",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Volunteer",
      "lastName": "Admin",
      "attributes": {
        "agencyId": ["agency-vol-001"],
        "agencyType": ["VolunteerAgency"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "test1234",
          "temporary": false
        }
      ],
      "realmRoles": ["vAdmin"],
      "groups": ["volunteer-agency-demo"]
    },
    {
      "username": "vcoord@test.org",
      "email": "vcoord@test.org",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Volunteer",
      "lastName": "Coordinator",
      "attributes": {
        "agencyId": ["agency-vol-001"],
        "agencyType": ["VolunteerAgency"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "test1234",
          "temporary": false
        }
      ],
      "realmRoles": ["vCoordinator"],
      "groups": ["volunteer-agency-demo"]
    }
  ]
}
